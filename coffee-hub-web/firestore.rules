rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admin_access/$(userEmail()));
    }

    function isDeliveryAgent() {
      return signedIn() &&
        exists(/databases/$(database)/documents/delivery_agents/$(userEmail()));
    }

    function isOrderOwner() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function isAssignedAgent() {
      return signedIn() &&
        (resource.data.agentEmail == userEmail() ||
          resource.data.deliveryAgentEmail == userEmail());
    }

    function isOrderOwnerById(orderId) {
      return signedIn() &&
        get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid;
    }

    function isAssignedAgentByOrder(orderId) {
      return signedIn() &&
        (get(/databases/$(database)/documents/orders/$(orderId)).data.agentEmail == userEmail() ||
          get(/databases/$(database)/documents/orders/$(orderId)).data.deliveryAgentEmail == userEmail());
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isOrderOwner() || isAssignedAgent();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /order_items/{itemId} {
      allow read: if isAdmin() ||
        (resource.data.orderDocId != null &&
          (isOrderOwnerById(resource.data.orderDocId) ||
            isAssignedAgentByOrder(resource.data.orderDocId))) ||
        (resource.data.orderDocId == null && signedIn());
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /delivery_agents/{agentId} {
      allow read: if isAdmin() || signedIn();
      allow create, update: if isAdmin() || (signedIn() && request.resource.data.email == userEmail());
      allow delete: if isAdmin();
    }

    match /delivery_sessions/{sessionId} {
      allow read: if isAdmin() ||
        isDeliveryAgent() ||
        (resource.data.orderDocId != null &&
          (isOrderOwnerById(resource.data.orderDocId) ||
            isAssignedAgentByOrder(resource.data.orderDocId)));
      allow write: if isAdmin() || isDeliveryAgent();
    }

    match /agent_locations/{sessionId} {
      allow read: if isAdmin() ||
        isDeliveryAgent() ||
        (resource.data.orderDocId != null &&
          (isOrderOwnerById(resource.data.orderDocId) ||
            isAssignedAgentByOrder(resource.data.orderDocId)));
      allow write: if isAdmin() || isDeliveryAgent();
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /admin_access/{email} {
      allow read: if isAdmin();
      allow create, update: if signedIn() && request.auth.token.email == email;
      allow delete: if isAdmin();
    }
  }
}
